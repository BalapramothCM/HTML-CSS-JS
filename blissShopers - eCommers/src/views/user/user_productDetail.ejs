<style>
  .product-page {
    padding-bottom: 70px;
  }

  .main-img-container {
    border: 1px solid #eee;
    border-radius: 12px;
    overflow: hidden;
  }

  .main-img {
    max-height: 450px;
    object-fit: cover;
    border-radius: 12px;
    transition: transform 0.3s ease;
  }
  .main-img:hover {
    transform: scale(1.02);
  }

  /* Thumbnails container */
  .thumbs-container {
    display: flex;
    gap: 10px;
    overflow-x: auto;
    padding-bottom: 5px;
    scrollbar-width: thin; /* for Firefox */
  }

  .thumbs-container::-webkit-scrollbar {
    height: 6px;
  }

  .thumbs-container::-webkit-scrollbar-thumb {
    background: #ccc;
    border-radius: 3px;
  }

  .thumbs-container::-webkit-scrollbar-track {
    background: #f1f1f1;
  }

  /* Thumbnail images */
  .thumb {
    flex: 0 0 auto;
    cursor: pointer;
    border-radius: 8px;
    transition: all 0.3s ease;
    height: 80px;
    width: 80px;
    object-fit: cover;
    border: 1px solid #eee;
  }

  .thumb:hover,
  .thumb.active {
    border: 2px solid #dc3545;
    transform: scale(1.05);
  }

  /* Product title */
  .product-title {
    font-weight: 700;
    font-size: 1.8rem;
    margin-bottom: 0.5rem;
  }

  .brand-text {
    font-size: 0.95rem;
    color: #6c757d;
  }

  /* Price styling */
  .price {
    font-size: 1.6rem;
    font-weight: 700;
    color: #dc3545;
  }
  .old-price {
    font-size: 1rem;
    text-decoration: line-through;
    color: #888;
    margin-left: 10px;
  }
  .offer {
    background: #ffe5e5;
    color: #dc3545;
    font-size: 0.85rem;
    font-weight: 600;
    padding: 3px 8px;
    border-radius: 6px;
    margin-left: 8px;
  }

  /* Size buttons */
  .btn.size {
    border-radius: 30px;
    padding: 6px 16px;
    font-size: 0.9rem;
    margin: 3px;
    transition: all 0.2s ease;
  }
  .btn.size:hover {
    background-color: #dc3545;
    color: #fff;
    border-color: #dc3545;
  }

  /* Info box */
  .info-box {
    background: #f8f9fa;
    border-radius: 12px;
    padding: 15px;
    margin-top: 15px;
  }

  /* Delivery section */
  .delivery p {
    margin-bottom: 6px;
    font-size: 0.9rem;
  }
  .delivery i {
    color: #28a745;
    margin-right: 6px;
  }
  /* Shake animation */
@keyframes shake {
  0% { transform: translateX(0); }
  25% { transform: translateX(-4px); }
  50% { transform: translateX(4px); }
  75% { transform: translateX(-4px); }
  100% { transform: translateX(0); }
}

.shake {
  animation: shake 0.3s;
}

/* Size warning message */
.size-warning {
  color: #dc3545;
  font-size: 0.9rem;
  margin-top: 5px;
  display: none;
  font-weight: 600;
}
@keyframes bagJumpShake {
  0% { transform: scale(1) rotate(0deg); }
  20% { transform: scale(1.3) rotate(0deg); }
  40% { transform: scale(1.3) rotate(-10deg); }
  60% { transform: scale(1.3) rotate(10deg); }
  80% { transform: scale(1.3) rotate(-6deg); }
  100% { transform: scale(1) rotate(0deg); }
}

.bag-shake {
  animation: bagJumpShake 0.6s ease;
}

#bagIcon,
#bagIconMobile {
  display: inline-block !important;
  transform-origin: center;
}
</style>

<main>
  <div class="container product-page">
    <div class="row g-4">
      <!-- Left Images -->
      <div class="col-md-6">
        <div class="main-img-container mb-3">
          <img src="data:<%= product.images[0].contentType %>;base64,<%= product.images[0].data.toString('base64') %>" 
               alt="<%= product.name %>" class="img-fluid main-img">
        </div>
        <h6>Select Image:</h6>
        <div class="thumbs-container mt-2 p-2">
          <% product.images.forEach((img, idx) => { %>
            <img src="data:<%= img.contentType %>;base64,<%= img.data.toString('base64') %>" 
                alt="<%= product.name %>" 
                class="thumb <%= idx === 0 ? 'active' : '' %>"
                data-index="<%= idx %>">
          <% }) %>
        </div>
        <p id="imageWarning" class="size-warning">Please select an image to continue</p>
      </div>

      <!-- Right Info -->
      <div class="col-md-6">
        <h2 class="product-title"><%= product.name %></h2>
        <p class="brand-text">Brand: <%= product.brand %></p>
        <p class="brand-text">Category: <%= product.category %> | <%= product.subCategory %></p>

        <div class="d-flex align-items-center mb-3">
          <span class="price">₹<%= product.finalPrice %></span>
          <span class="old-price">₹<%= product.price %></span>
          <span class="offer"><%= product.discountPercent %>% OFF</span>
        </div>

        <% if (product.category !== "Trending Sarees") { %>
          <div class="my-3">
            <h6>Select Size</h6>
            <p id="sizeWarning" class="size-warning">Please select a size to continue</p>
            <% product.sizes.forEach(s => { 
                if (s.stock !== 0) { %>
              <button class="btn btn-outline-secondary size">
                <%= s.size %>
              </button>
            <% } }) %>
          </div>
        <% } else { %>
          <p id="sizeWarning" class="size-warning">Please select a size to continue</p>
          <% product.sizes.forEach(s => { 
              if (s.stock !== 0 && s.size == "OneSize") { %>
              <button class="btn btn-outline-secondary size">
                <%= s.size %>
              </button>
            <% } }) %>
        <% } %>

        <!-- Action Buttons -->
        <div class="d-flex gap-3 my-4">
          <button
            class="btn btn-danger flex-grow-1"
            onclick="validateSizeBeforeAdd('<%= product._id %>', '<%= product.finalPrice %>', getSelectedImageIndex())">
            <i class="fa fa-shopping-bag"></i> Add to Bag
          </button>
        </div>

        <!-- Product Details -->
        <div class="info-box">
          <h6><i class="fa-solid fa-book"></i> Product Details</h6>
          <pre style="font-family: inherit; white-space: pre-wrap;"><%= product.description %></pre>
        </div>

        <!-- Delivery -->
        <div class="info-box delivery mt-3">
          <p><i class="fa-solid fa-circle-check"></i> 100% Original Product</p>
          <p><i class="fa-solid fa-circle-check"></i> Easy 7 days returns and exchanges</p>
        </div>
      </div>
    </div>
  </div>
</main>

<script>
  let currentImageIndex = 0; // default: first image
  let hasUserSelectedImage = false; // track if user clicked any image

  function getSelectedSize() {
    let activeBtn = document.querySelector(".btn.size.active");
    return activeBtn ? activeBtn.innerText.trim().replace("(Out)", "").trim() : null;
  }

  function getSelectedImageIndex() {
    return currentImageIndex;
  }

  // Size selection
  document.querySelectorAll(".btn.size").forEach(btn => {
    btn.addEventListener("click", () => {
      document.querySelectorAll(".btn.size").forEach(b => b.classList.remove("active"));
      btn.classList.add("active");

      // hide warning
      const sizeWarning = document.getElementById("sizeWarning");
      if (sizeWarning) sizeWarning.style.display = "none";
    });
  });

  // Thumbnail click: change main image + update index
  const mainPic = document.querySelector(".main-img");
  document.querySelectorAll(".thumb").forEach(thumb => {
    thumb.addEventListener("click", () => {

       // Mark user has clicked an image
      hasUserSelectedImage = true;

      // update active class on thumbs
      document.querySelectorAll(".thumb").forEach(t => t.classList.remove("active"));
      thumb.classList.add("active");

      // update main image src
      mainPic.src = thumb.src;

      // store index
      currentImageIndex = parseInt(thumb.dataset.index, 10);

      // hide warning
      const imageWarning = document.getElementById("imageWarning");
      if (imageWarning) imageWarning.style.display = "none";
    });
  });
  // FINAL VALIDATION BEFORE ADD TO BAG
  function validateSizeBeforeAdd(productId, price, imageIndex) {
    // SIZE VALIDATION
    const selectedSize = getSelectedSize();
    const sizeButtons = document.querySelectorAll(".btn.size");
    const sizeWarning = document.getElementById("sizeWarning");

    if (!selectedSize) {
      sizeWarning.style.display = "block";

      sizeButtons.forEach(btn => {
        btn.classList.add("shake");
        setTimeout(() => btn.classList.remove("shake"), 350);
      });

      return;
    }

    sizeWarning.style.display = "none";

    // IMAGE VALIDATION  
    const imageWarning = document.getElementById("imageWarning");

    if (!hasUserSelectedImage) {
      imageWarning.style.display = "block";

      const thumbsContainer = document.querySelector(".thumbs-container");
      thumbsContainer.classList.add("shake");
      setTimeout(() => thumbsContainer.classList.remove("shake"), 350);

      document.querySelectorAll(".thumb").forEach(t => {
        t.classList.add("shake");
        setTimeout(() => t.classList.remove("shake"), 350);
      });

      return;
    }

    imageWarning.style.display = "none";

    // ---------------------------
    // ADD PRODUCT TO BAG
    // ---------------------------
    addToBag(productId, selectedSize, price, imageIndex);

    // Shake DESKTOP bag icon
    const bagIcon = document.getElementById("bagIcon");
    if (bagIcon) {
      bagIcon.classList.add("bag-shake");
      setTimeout(() => bagIcon.classList.remove("bag-shake"), 600);
    }

    // Shake MOBILE bag icon
    const bagIconMobile = document.getElementById("bagIconMobile");
    if (bagIconMobile) {
      bagIconMobile.classList.add("bag-shake");
      setTimeout(() => bagIconMobile.classList.remove("bag-shake"), 600);
    }
  }

  window.validateSizeBeforeAdd = validateSizeBeforeAdd;
</script>