<main class="container py-5">
  <h2 class="mb-4 fw-bold text-center">🛒 Your Shopping Cart</h2>

  <div id="cartItems" class="mt-4"></div>

  <div class="d-flex justify-content-between align-items-center mt-4 border-top pt-4 cart-footer">
    <h4 class="mb-0 fw-bold">Total: <span class="text-success">₹<span id="cartTotal">0</span></span></h4>
    <button onclick="redirectToCheckout()" class="btn btn-lg btn-success px-4 shadow-sm">
      Proceed to Checkout <i class="fa fa-arrow-right ms-2"></i>
    </button>
  </div>
</main>

<style>
  .cart-item { border-radius: 12px; box-shadow: 0 3px 8px rgba(0,0,0,0.08); transition: transform 0.2s ease-in-out; }
  .cart-item:hover { transform: translateY(-2px); }
  .cart-item img { border-radius: 10px; object-fit: cover; }
  .cart-item-title { font-size: 1rem; font-weight: 600; }
  .cart-item-sub { font-size: 0.85rem; color: #6c757d; }
  .cart-footer { background: #fff; border-radius: 12px; padding: 15px 20px; box-shadow: 0 -2px 8px rgba(0,0,0,0.05); }
  .empty-cart { text-align: center; padding: 50px 20px; background: #f8f9fa; border-radius: 15px; }
</style>

<script>
  let cartData = []; // keep backend data in memory

  document.addEventListener("DOMContentLoaded", async () => {
    let cart = JSON.parse(localStorage.getItem("cart")) || [];

    if (cart.length === 0) {
      document.getElementById("cartItems").innerHTML = `
        <div class="empty-cart">
          <img src="https://cdn-icons-png.flaticon.com/512/2038/2038854.png" width="100" class="mb-3"/>
          <h5>Your cart is empty</h5>
          <p class="text-muted">Looks like you haven't added anything yet.</p>
          <a href="/" class="btn btn-outline-primary mt-3">Continue Shopping</a>
        </div>`;
      return;
    }

    try {
      let response = await fetch("/cartDetails", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ cart })
      });

      let data = await response.json();
      cartData = data.items || [];

      console.log(cartData);
      

      if (!cartData.length) {
        document.getElementById("cartItems").innerHTML = `
          <div class="alert alert-warning text-center">Cart items not found.</div>`;
        return;
      }

      renderCart(cartData);
      updateCartTotal();

    } catch (err) {
      console.error(err);
      alert("⚠️ Something went wrong while fetching your cart.");
    }
  });

  function renderCart(items) {
    let html = `<div class="list-group">`;

    items.forEach(item => {
      const quantity = getItemQuantity(item.id, item.size);
      html += `
        <div class="list-group-item cart-item d-flex justify-content-between align-items-center mb-3">
          <div class="d-flex align-items-center">
            <img src="${item.image}" width="70" height="70" class="me-3 border"/>
            <div>
              <a href="/productDetail/${item.id}" class="cart-item-title text-dark text-decoration-none">
                ${item.name}
              </a>
              ${item.size ? `<div class="cart-item-sub">Size: ${item.size}</div>` : ""}

              <!-- Quantity dropdown -->
              <div class="mt-2">
                <label class="form-label small me-2">Qty:</label>
                <select 
                  class="form-select d-inline-block w-auto qtySelect"
                  data-id="${item.id}"
                  data-size="${item.size || ""}"
                  data-price="${item.price}">
                  ${[...Array(Math.min(item.stockQty, 5)).keys()]
                    .map(i => `<option value="${i + 1}" ${quantity === i + 1 ? "selected" : ""}>${i + 1}</option>`)
                    .join('')}
                </select>
              </div>
            </div>
          </div>
          <div class="d-flex align-items-center gap-3">
            <span class="fw-bold text-success fs-5">₹${item.price}</span>
            <button class="btn btn-sm btn-outline-danger rounded-circle" 
                    onclick="removeFromCart('${item.id}', '${item.size || ""}', ${item.imageIndex ?? 0})">
              <i class="fa fa-trash"></i>
            </button>
          </div>
        </div>
      `;
    });

    html += `</div>`;
    document.getElementById("cartItems").innerHTML = html;

    // Attach change listeners
    document.querySelectorAll(".qtySelect").forEach(select => {
      select.addEventListener("change", (e) => {
        const prodId = e.target.dataset.id;
        const size = e.target.dataset.size;
        const newQty = parseInt(e.target.value);
        updateCartQuantity(prodId, size, newQty);
        updateCartTotal();
      });
    });
  }

  function getItemQuantity(id, size) {
    let cart = JSON.parse(localStorage.getItem("cart")) || [];
    const found = cart.find(item => item.id === id && item.size === size);
    return found ? (found.quantity || 1) : 1;
  }

  function updateCartQuantity(prodId, size, quantity) {
    let cart = JSON.parse(localStorage.getItem("cart")) || [];
    cart = cart.map(item => {
      if (item.id === prodId && item.size === size) {
        return { ...item, quantity };
      }
      return item;
    });
    localStorage.setItem("cart", JSON.stringify(cart));
  }

  function updateCartTotal() {
    let total = 0;
    document.querySelectorAll(".qtySelect").forEach(select => {
      const qty = parseInt(select.value);
      const price = parseFloat(select.dataset.price);
      total += qty * price;
    });
    document.getElementById("cartTotal").textContent = total.toFixed(2);
  }

  function removeFromCart(prodId, size = "", imageIndex = 0) {
    let cart = JSON.parse(localStorage.getItem("cart")) || [];

    imageIndex = Number(imageIndex); // normalize

    cart = cart.filter(item => {
      const itemSize = item.size || "";
      const itemImageIndex = Number(item.imageIndex ?? 0);

      // keep the item if it is NOT the same id + size + imageIndex
      return !(item.id === prodId && itemSize === size && itemImageIndex === imageIndex);
    });

    localStorage.setItem("cart", JSON.stringify(cart));
    location.reload();
  }


  function redirectToCheckout() {
    let cart = JSON.parse(localStorage.getItem("cart")) || [];
    if (cart.length === 0) return;
    window.location.href = "/checkout";
  }
</script>