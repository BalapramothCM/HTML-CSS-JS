<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard</title>
    <link rel="icon" href="/images/logo.png" type="image/x-icon">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        :root {
            --sidebar-bg-color: #f8f9fa; /* Very light grey/white for sidebar background */
            --sidebar-text-color: #343a40; /* Dark text for sidebar */
            --sidebar-hover-bg: #ffe0b2; /* Very light orange on hover */
            --sidebar-active-bg: #ffcc80; /* Slightly darker light orange for active */
            --accent-orange: #ffab40; /* A soft, visible orange for accents like buttons */
            --navbar-bg-color: #ffffff; /* Pure white for navbar */
            --navbar-text-color: #343a40; /* Dark text for navbar */
        }

        html,body {
            overflow-x: hidden; /* Prevent horizontal scroll */
            background-color: #f0f2f5; /* A light background for the main page */
            height: 100%;
            margin: 0;
            padding: 0;
        }
       
        #wrapper {
            display: flex;
            height: 100vh; /* Make wrapper take full screen */
            overflow: hidden;
        }

        #sidebar-wrapper {
            min-height: 100vh;
            margin-left: -15rem; /* Hidden by default */
            transition: margin .25s ease-out;
            width: 15rem;
            background-color: var(--sidebar-bg-color);
            color: var(--sidebar-text-color);
            flex-shrink: 0;
            border-right: 1px solid #dee2e6; /* Light border */
        }

        #sidebar-wrapper .sidebar-heading {
            padding: 0.875rem 1.25rem;
            font-size: 1.2rem;
            color: var(--sidebar-text-color);
            border-bottom: 1px solid rgba(0, 0, 0, 0.05); /* Very light border */
            font-weight: bold;
        }
        #sidebar-wrapper .list-group {
            width: 100%;
        }
        #sidebar-wrapper .list-group-item {
            color: var(--sidebar-text-color);
            background-color: var(--sidebar-bg-color);
            border: none;
            padding: 0.875rem 1.25rem;
            transition: background-color 0.2s, color 0.2s;
        }
        #sidebar-wrapper .list-group-item:hover {
            background-color: var(--sidebar-hover-bg);
            color: var(--sidebar-text-color); /* Keep text dark for contrast */
        }
        .action-btn {
            background-color: var(--sidebar-bg-color);
            transition: background-color 0.2s, color 0.2s;
            border: 1px solid var(--sidebar-text-color);
        }
        .action-btn:hover{
            background-color: var(--sidebar-hover-bg);
            border: 1px solid var(--sidebar-text-color);
        }
        #sidebar-wrapper .list-group-item.active {
            background-color: var(--sidebar-active-bg);
            color: var(--sidebar-text-color); /* Keep text dark for contrast */
            font-weight: bold;
        }
        #page-content-wrapper {
            min-width: 100vw;
            flex-grow: 1;
        }

        /* Navbar specific styles */
        .navbar {
            background-color: var(--navbar-bg-color) !important;
            border-bottom: 1px solid #dee2e6; /* Light border */
        }
        .navbar .btn-primary {
            background-color: var(--accent-orange);
            border-color: var(--accent-orange);
            color: white; /* Ensure text is white for contrast */
        }
        .navbar .btn-primary:hover {
            background-color: #fb8c00; /* Slightly darker orange on hover */
            border-color: #fb8c00;
        }
        .navbar .btn-outline-danger {
            color: #dc3545; /* Bootstrap danger red */
            border-color: #dc3545;
        }
        .navbar .btn-outline-danger:hover {
            background-color: #dc3545;
            color: white;
        }


        /* Toggle Styles */
        /* When 'toggled' class is on the body, show the sidebar */
        body.toggled #sidebar-wrapper {
            margin-left: 0; /* Show sidebar */
        }
        /* When 'toggled' class is on the body, reduce the main content width for desktop */
        @media (min-width: 768px) {
            body.toggled #page-content-wrapper {
                margin-left: -15rem; /* This pulls the content left to hide the sidebar */
                transition: margin .25s ease-out; /* Smooth transition */
            }
        }


        @media (min-width: 768px) {
            #sidebar-wrapper {
                margin-left: 0; /* Always show sidebar on larger screens by default */
            }
            #page-content-wrapper {
                min-width: 0; /* Allow content to shrink */
                width: 100%; /* Take full width minus sidebar */
            }
            /* When 'toggled' on larger screens, hide sidebar and expand content */
            body.toggled #sidebar-wrapper {
                margin-left: -15rem; /* Hide sidebar */
            }
            body.toggled #page-content-wrapper {
                margin-left: 0; /* No margin, takes full width */
            }
        }
    </style>
</head>
<body>

   <div class="d-flex" id="wrapper">
        <% if(session.role === "admin") { %>  
            <%- include('../admin/admin_sidebar')  %>
        <% } %>
        <div id="page-content-wrapper">
            <% if(session.role === "admin") { %> 
                <nav class="navbar navbar-expand-lg navbar-light border-bottom">
                    <div class="container-fluid">
                        <button class="btn btn-primary" id="sidebarToggle">
                            <i class="bi bi-list"></i>
                        </button>

                        <a class="btn btn-outline-danger" href="/api/admin/logout">
                            <i class="bi bi-box-arrow-right"></i> Logout
                        </a>
                    </div>
                </nav>
            <% } %>

            <div class="container-fluid overflow-auto" style="height: 92vh">
                <%- body %>
            </div>
        </div>
   </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var sidebarToggle = document.getElementById('sidebarToggle');

            if (sidebarToggle) {
                sidebarToggle.addEventListener('click', function() {
                    // Corrected: Toggle the 'toggled' class on the <body> element
                    document.body.classList.toggle('toggled');
                });
            }
        });
    </script>
</body>
</html>