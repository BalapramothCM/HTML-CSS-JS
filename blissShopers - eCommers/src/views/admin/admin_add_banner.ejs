 <% if (mess) { %>
  <div class="alert alert-info text-center m-2" id="messAlert" role="alert">
    <p class="mb-2 text-dark"><%= mess%></p>
  </div>
 <% } %>

<div class="container-fluid mt-3">
  <div class="row">
     <!-- Add Banner Card -->
    <div class="col-md-12 mb-3">
        <div class="card shadow-sm border-0 h-100">
        <div class="card-header bg-light">
          <h5 class="mb-0">Add banner</h5>
        </div>
        <div class="card-body rounded">
          <div class="row g-3">
            <form action="/api/admin/addBanner" method="POST" enctype="multipart/form-data">
           
               <div class="col-12">
                  <label for="title" class="form-label">Banner Title</label>
                  <input type="text" class="form-control" id="title" maxlength="20" name="title" placeholder="Enter banner title" required />
               </div>
               
               <div class="col-12">
                     <label for="image" class="form-label">Banner Image</label>
                  <input type="file" class="form-control" id="image" name="image" accept="image/*" required />
               </div>

               <div id="preview" class="mt-3 text-center"></div>

               <div class="col-auto" id="save-btn-div">
                  <button type="submit" id="banrSaveBtn" class=" btn btn-outline-success fw-bold">
                     <i class="bi bi-floppy me-2"></i>Save
                  </button>
               </div>
            </form>  

              <strong>
                <i>
                   <p style="font-size: medium; display: none;" id="category-mess"></p>
                </i>
             </strong>
          </div>
        </div>
        </div>
    </div>
 
  </div>
</div>

<!-- Banner Table -->
<div class="card my-4 shadow-sm border-0">
  <div class="card-header bg-light text-center">
    <h5 class="mb-0">📋 Banner List</h5>
  </div>
  <div class="card-body p-0">
    <table class="table table-hover mb-0">
      <thead class="table-light">
        <tr>
          <th scope="col">#</th>
          <th scope="col">Image</th>
          <th scope="col">Title</th>
          <th scope="col">Actions</th>
        </tr>
      </thead>
      <tbody>
         <% bannersList.forEach((banner, idx) => { %>
            <tr>
               <th scope="row"><%= idx + 1 %></th>
               <td>
               <% if (banner.imageBase64) { %>
                  <img 
                     src="<%= banner.imageBase64 %>"
                     alt="Banner Image" 
                     style="max-height:60px; max-width:120px;" 
                     class="img-thumbnail"
                  />
               <% } else { %>
                  <span class="text-muted">No Image</span>
               <% } %>
               </td>
               <td><%= banner.title %></td>
               <td>
               <div class="d-flex gap-2">
                  <form action="/api/admin/deleteBanner/<%= banner._id %>" method="POST" style="display:inline;">
                     <button type="submit" title="Delete Banner" class="btn btn-danger btn-sm" onclick="return confirm('Delete this banner?')">
                     <i class="bi bi-trash"></i>
                     </button>
                  </form>
               </div>
               </td>
            </tr>
         <% }) %>
      </tbody>
     
    </table>
  </div>
</div>

<script>
  // Preview selected image
  document.getElementById('image').addEventListener('change', function(event) {
    const preview = document.getElementById('preview');
    preview.innerHTML = '';
    const file = event.target.files[0];
    if (file) {
      const img = document.createElement('img');
      img.src = URL.createObjectURL(file);
      img.className = 'img-fluid rounded shadow-sm mt-2';
      img.style.maxHeight = '180px';
      preview.appendChild(img);
    }
  });
</script>