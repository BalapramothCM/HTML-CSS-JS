<% 
  const defaultCategorySelect = "Saree"
%>

<% if (mess) { %>
  <div class="alert alert-info text-center m-2 shadow-sm rounded-3" id="messAlert" role="alert">
    <i class="bi bi-info-circle-fill me-2"></i>
    <span class="mb-2 text-dark fw-semibold"><%= mess %></span>
  </div>
<% } else { %>
  <div class="position-sticky top-0 z-3 bg-white d-flex flex-wrap mt-2 mb-2 align-items-end justify-content-start gap-3 p-3 shadow-sm rounded-2" style="width: 100%;">
    <div>
      <label class="form-label fw-bold text-dark mb-1">
        <i class="bi bi-tags-fill me-1"></i>Category
      </label>
      <select id="category" name="category" class="form-select shadow-sm" style="min-width: 180px;" required>
        <% categories.forEach(c => { %>
          <option value="<%= c.category %>" <%= c.category === defaultCategorySelect ? "selected" : "" %>><%= c.category %></option>
        <% }) %>
      </select>
    </div>
    <div>
      <label class="form-label fw-bold text-dark mb-1">
        <i class="bi bi-tag-fill me-1"></i>Subcategory
      </label>
      <select id="subCategory" name="subCategory" class="form-select shadow-sm" style="min-width: 180px;" required>
        <option value="">--All--</option>
      </select>
    </div>
    <div>
      <button type="submit"  id="search-Btn" onclick="resetAndLoadProducts()" class=" btn btn-outline-dark fw-bold shadow-sm px-4 d-flex align-items-center">
        <i class="bi bi-search me-2"></i>Search
      </button>
    </div>
  </div>

  <div class="my-2">
    <h3 class="mb-2 text-dark fw-semibold text-center">Products</h3>
    <div id="product-list" class="row row-cols-1 row-cols-sm-2  row-cols-md-3 g-4">
      <!-- Product cards will be injected here -->
    </div>
    <div id="spinner" class="text-center my-4" style="display: none;">
      <div class="spinner-grow text-warning" role="status">
        <span class="visually-hidden">Loading...</span>
      </div>
    </div>
  </div>
<% } %>
<script>

  const categoryDrpDwn = document.getElementById("category");
  const subCategoryDrpDwn = document.getElementById("subCategory");
  const spinner = document.getElementById("spinner");
  let skip = 0;
  const limit = 20;
  let isLoading = false;
  let allLoaded = false;

  //add subCategory on load.
  getSubCategories(categoryDrpDwn.value)
  
  //add subCategory onchange category.
  categoryDrpDwn.addEventListener('change', async (e) => {
    const categoryValue = e.target.value;
  
    // Clear previous subcategories
    subCategoryDrpDwn.innerHTML = '<option value="">--All--</option>';
  
    if (categoryValue) {
      getSubCategories(categoryValue)
    }
  });

  async function getSubCategories(categoryValue){
    try {
        const res = await fetch(`/api/admin/getsubcategories/${categoryValue}`);
        const data = await res.json();

        // Assuming data.subCategoryArr is an sub_category array
        if (res.ok) {
          const subCategories = data.subCategoryArr;

          subCategories.forEach(subCat => {
            const option = document.createElement('option');
            option.value = subCat;
            option.textContent = subCat;
            subCategoryDrpDwn.appendChild(option);
          });
        }
      } 
      catch (err) {
        console.error("Error fetching subcategories:", err);
      }
  }
  
  async function loadProducts() {
    if (isLoading || allLoaded) return;
    
    isLoading = true;
    spinner.style.display = "block";

    try{
      const response = await fetch('/api/admin/getallproducts', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ category:categoryDrpDwn.value, subCategory : subCategoryDrpDwn.value, skip, limit}) // add filters if needed
      });

      const data = await response.json();

      if (response.ok && data.productArr.length > 0) {
        renderProducts(data.productArr);
        skip += limit;
      } else {
        allLoaded = true;
      }
    }
    catch(err){
      alert("Something went wrong while loading products. Please try again later.");
  } finally {
    spinner.style.display = "none";
    isLoading = false;
  }
  }

  function renderProducts(products) {
    const productListDiv = document.getElementById("product-list");

    products.forEach(product => {
      const card = document.createElement("div");
      card.className = "col";

      card.innerHTML = `
        <div class="card mb-3 shadow-sm border-0 h-100" style="max-width: 600px;">
          <div class="row g-0 h-100">
            <div class="col-md-4">
              <img src="${product.imageBase64 || 'https://via.placeholder.com/150'}" 
                  class="img-fluid rounded-start h-100 w-100" 
                  alt="${product.name}" 
                  style="object-fit: cover;">
            </div>
            <div class="col-md-8">
              <div class="card-body h-100 d-flex flex-column justify-content-between">
                <div>
                  <h5 class="card-title fw-bold text-primary">${product.name}</h5>
                  <p class="card-text mb-1"><strong>Brand:</strong> ${product.brand}</p>
                  <p class="card-text mb-1"><strong>Price:</strong> ₹${product.finalPrice}</p>
                  <p class="card-text text-success mb-0"><strong>Discount:</strong> ${product.discountPercent}% off</p>
                </div>
                <div class="mt-3 d-flex justify-content-end">
                  <a type="button" class=" btn btn-outline-dark fw-bold" 
                    href="/api/admin/editproduct/${product._id}" title="Edit Product">
                    <i class="bi bi-pencil-square me-1"></i>Edit
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      `;

      productListDiv.appendChild(card);
    });
  }
  
  function resetAndLoadProducts() {
  // Reset variables
  skip = 0;
  allLoaded = false;
  document.getElementById("product-list").innerHTML = "";

  loadProducts(); // Call your loader
}
 
  // Load first 20 on page load
  window.addEventListener('DOMContentLoaded', loadProducts);

  // Infinite scroll detection with debounce and better threshold
  const scrollContainer = document.querySelector('.container-fluid.overflow-auto');
  let scrollTimeout;
  if (scrollContainer) {
    scrollContainer.addEventListener('scroll', () => {
      if (scrollTimeout) clearTimeout(scrollTimeout);
      scrollTimeout = setTimeout(() => {
        // Check if near bottom (150px from bottom)
        if (scrollContainer.scrollTop + scrollContainer.clientHeight >= scrollContainer.scrollHeight - 100) {
          loadProducts();
        }
      }, 100);
    });
  }

  </script>